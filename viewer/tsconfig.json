{
  "compilerOptions": {
    "target":                "ES2022",
    "module":                "ES2022",
    "moduleResolution":      "Bundler",
    "strict":                true,
    "noImplicitOverride":    true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns":     true,
    "exactOptionalPropertyTypes": true,
    "lib":                   ["ES2022", "DOM"],
    "skipLibCheck":          true,
    "esModuleInterop":       true,
    "isolatedModules":       true,
    "noEmit":                true
  },
  "include": ["src/**/*.ts"]
}
