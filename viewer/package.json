  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:prod": "cross-env NODE_ENV=production node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild":                  "0.24.0",
