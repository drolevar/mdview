{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 27, "patch": 0 },
    "configurePresets": [
        {
            "name": "windows-msvc-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-msvc-x64-debug",
            "inherits": "windows-msvc-base",
            "architecture": { "value": "x64", "strategy": "external" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static"
            }
        },
        {
            "name": "windows-msvc-x64-release",
            "inherits": "windows-msvc-base",
            "architecture": { "value": "x64", "strategy": "external" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static"
            }
        },
        {
            "name": "windows-msvc-x86-debug",
            "inherits": "windows-msvc-base",
            "architecture": { "value": "x86", "strategy": "external" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "VCPKG_TARGET_TRIPLET": "x86-windows-static"
            }
        },
        {
            "name": "windows-msvc-x86-release",
            "inherits": "windows-msvc-base",
            "architecture": { "value": "x86", "strategy": "external" },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "VCPKG_TARGET_TRIPLET": "x86-windows-static"
            }
        }
    ],
    "buildPresets": [
        { "name": "windows-msvc-x64-debug",   "configurePreset": "windows-msvc-x64-debug" },
        { "name": "windows-msvc-x64-release", "configurePreset": "windows-msvc-x64-release" },
        { "name": "windows-msvc-x86-debug",   "configurePreset": "windows-msvc-x86-debug" },
        { "name": "windows-msvc-x86-release", "configurePreset": "windows-msvc-x86-release" }
    ],
    "testPresets": [
        {
            "name": "windows-msvc-x64-debug",
            "configurePreset": "windows-msvc-x64-debug",
            "output": { "outputOnFailure": true },
            "execution": { "noTestsAction": "error", "stopOnFailure": false }
        },
        {
            "name": "windows-msvc-x86-debug",
            "configurePreset": "windows-msvc-x86-debug",
            "output": { "outputOnFailure": true },
            "execution": { "noTestsAction": "error", "stopOnFailure": false }
        }
    ]
}
